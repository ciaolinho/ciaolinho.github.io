@echo off
chcp 65001 >nul
echo ========================================================
echo   🌌 Surge.sh 一鍵網頁發佈工具 (Netlify 替代方案)
echo ========================================================
echo.
echo 本工具將協助您將目前的教學儀表板與所有工具網頁發佈到網路上。
echo.
echo 💡 操作步驟說明：
echo 1. 第一次使用，請輸入您的【常用 Email】與【自訂密碼】。
echo    (注意：密碼輸入時畫面上「不會顯示任何字元或星號」，請直接打完按 Enter)
echo    * 如果該 Email 尚未註冊，Surge 會在您按下 Enter 後自動為您註冊！
echo.
echo 2. 隨後會詢問 "project:"，預設即為當前資料夾，直接按【Enter】繼續。
echo.
echo 3. 最後會詢問 "domain:"，您可以自訂一個專屬網址，
echo    例如修改為：ciaolinho-dashboard.surge.sh (結尾必須是 .surge.sh)
echo    然後按下【Enter】即開始上傳！
echo.
echo ========================================================
echo.
npx surge .
echo.
echo --------------------------------------------------------
echo 🎉 部署流程結束！請複製上方顯示的 domain 網址，即可在瀏覽器開啟。
echo --------------------------------------------------------
pause 1

 